# ──────────────────────────────────────────────────────────────
# Hood Terminal Backend — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ─── Robinhood Chain RPC (Alchemy) ───────────────────────────
RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_WSS=wss://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://hood:hood@localhost:5432/hood_terminal
# Set to false for Supabase pooler URLs if Node rejects the cert chain.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ─── Browser Sessions ────────────────────────────────────────
# Set a long random value in production. Used to sign wallet-session cookies.
SESSION_SECRET=change-me-to-a-long-random-production-secret
SESSION_COOKIE_NAME=hood_session
SESSION_TTL_SECONDS=604800
# For cross-site hosted frontend/backend over HTTPS, keep true.
COOKIE_SECURE=true

# ─── Auth ────────────────────────────────────────────────────
# Set to "true" to enforce x-api-key even in development
REQUIRE_AUTH=false

# ─── Scan Engine ─────────────────────────────────────────────
SCAN_TIMEOUT_MS=10000
SCAN_CONCURRENCY=31
CACHE_SCAN_TTL_S=300

# ─── Block Explorer (optional — fallback for deployer/source resolution) ─
EXPLORER_API_URL=https://robinhoodchain.blockscout.com
EXPLORER_API_KEY=

# ─── DEX Addresses (Robinhood Chain) ────────────────────────────
# Wrapped native token
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
# Primary DEX router: Uniswap V2 Router02
DEX_ROUTER_ADDRESS=0x89e5db8b5aa49aa85ac63f691524311aeb649eba
# Optional routers as name:address, comma-separated.
DEX_ROUTERS=UniswapV2:0x89e5db8b5aa49aa85ac63f691524311aeb649eba,PancakeV2:0x8cFe327CEc66d1C090Dd72bd0FF11d690C33a2Eb
# Primary DEX factory: Uniswap V2 Factory
DEX_FACTORY_ADDRESS=0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f
# Optional additional factories as name:address:type, comma-separated. type can be v2 or v3.
DEX_FACTORIES=UniswapV2:0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f:v2,PancakeV2:0x02a84c1b3BBD7401a5f7fa98a384EBC70bB5749E:v2,UniswapV3:0x1F7d7550B1b028F7571e69a784071F0205fD2EfA:v3
# ERC20/V2 LP lockers as name:address, comma-separated.
# Note: launchpads using Uniswap V3 NFT lockers need ABI-specific support.
LP_LOCKER_ADDRESSES=
# Launchpads as name:address:type:startBlock, comma-separated.
# type can be bonding_curve, factory, locker, unknown. ArrowPad, Sentry, and NOXA Fun are built-in defaults.
LAUNCHPAD_CONTRACTS=ArrowPad:0x5d2391CF88cd48BB6B9Ec12b38BC8119562F9012:bonding_curve:1833466,Sentry:0x9e8f6f8214b01Fd4Cf1d73FB1fb7cf9f811036Cb:factory:1431636,NOXAFun:0xD9eC2db5f3D1b236843925949fe5bd8a3836FCcB:factory:61688

# ─── Chain ID (update when confirmed) ───────────────────────
# Confirmed from RPC eth_chainId: 0x1237
CHAIN_ID=4663
